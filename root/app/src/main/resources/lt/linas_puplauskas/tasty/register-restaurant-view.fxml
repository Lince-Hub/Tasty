<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="384.0" prefWidth="639.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lt.linas_puplauskas.tasty.fxControllers.RegisterRestaurantController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Pane prefHeight="414.0" prefWidth="498.0">
         <children>
            <Pane layoutX="-34.0" prefHeight="335.0" prefWidth="334.0">
               <children>
                  <TextField fx:id="usernameField" layoutX="167.0" layoutY="50.0" promptText="Enter username" />
                  <PasswordField fx:id="passwordField" layoutX="167.0" layoutY="83.0" promptText="Password" />
                  <PasswordField fx:id="repeatPasswordField" layoutX="167.0" layoutY="116.0" promptText="Repeat Password" />
                  <TextField fx:id="emailField" layoutX="167.0" layoutY="149.0" promptText="Email" />
                  <TextField fx:id="phoneField" layoutX="167.0" layoutY="182.0" promptText="Phone" text="+370" />
                  <Label layoutX="57.0" layoutY="54.0" text="Username" />
                  <Label layoutX="57.0" layoutY="87.0" text="Password" />
                  <Label layoutX="57.0" layoutY="120.0" text="Repeat Password" />
                  <Label layoutX="57.0" layoutY="153.0" text="Email" />
                  <Label layoutX="57.0" layoutY="186.0" text="Phone" />
                  <Button layoutX="110.0" layoutY="248.0" mnemonicParsing="false" onAction="#createRestaurant" text="Create Restaurant" />
                  <Button layoutX="135.0" layoutY="296.0" mnemonicParsing="false" onAction="#goBack" text="Go Back" />
               </children>
            </Pane>
            <Separator layoutX="283.0" layoutY="41.0" orientation="VERTICAL" prefHeight="299.0" prefWidth="34.0" />
            <Pane fx:id="restaurantPane" layoutX="258.0" prefHeight="344.0" prefWidth="319.0">
               <children>
                  <Label layoutX="56.0" layoutY="54.0" text="Description" />
                  <TextArea fx:id="descriptionField" layoutX="167.0" layoutY="48.0" prefHeight="58.0" prefWidth="149.0" promptText="Enter description" />
                  <Label layoutX="56.0" layoutY="121.0" text="Address" />
                  <TextField fx:id="addressField" layoutX="167.0" layoutY="117.0" promptText="Enter Address" />
                  <Label layoutX="56.0" layoutY="156.0" text="Cuisine" />
                  <ComboBox fx:id="cuisineComboBox" layoutX="166.0" layoutY="152.0" prefWidth="150.0" />
                  <Label layoutX="56.0" layoutY="194.0" text="Opening Time" />
                  <Label layoutX="56.0" layoutY="231.0" text="Closing Time" />
                  <Label layoutX="56.0" layoutY="269.0" text="Happy hour start" />
                  <Label layoutX="56.0" layoutY="309.0" text="Happy hour end" />
                  <TextField fx:id="openingTimeField" layoutX="167.0" layoutY="190.0" />
                  <TextField fx:id="closingTimeField" layoutX="167.0" layoutY="227.0" />
                  <TextField fx:id="happyHourStartField" layoutX="166.0" layoutY="265.0" />
                  <TextField fx:id="happyHourEndField" layoutX="166.0" layoutY="305.0" />
               </children>
            </Pane>
            <Label alignment="CENTER" layoutX="197.0" layoutY="-10.0" prefHeight="48.0" prefWidth="207.0" text="Create Restaurant">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
         </children></Pane>
   </children>
</VBox>
