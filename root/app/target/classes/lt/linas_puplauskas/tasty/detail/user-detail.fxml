<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefWidth="550" spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lt.linas_puplauskas.tasty.fxControllers.detail.UserDetailController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Label text="User Details"><font><Font size="18" /></font></Label>

    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Username" />
        <TextField fx:id="usernameField" />
    </HBox>
   <HBox alignment="CENTER" spacing="10">
      <children>
         <Label prefWidth="130" text="Password" />
         <TextField fx:id="passwordField" />
      </children>
   </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Email" />
        <TextField fx:id="emailField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Phone" />
        <TextField fx:id="phoneField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Role" />
      <ComboBox fx:id="roleField" prefWidth="150.0" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Date Created" />
        <TextField fx:id="dateCreatedField" editable="false" />
    </HBox>

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#save" text="Save" />
        <Button onAction="#close" text="Close" />
    </HBox>
</VBox>
