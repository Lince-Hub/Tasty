<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="512.0" prefWidth="550.0" spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lt.linas_puplauskas.tasty.fxControllers.detail.ClientDetailController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Label text="Client Details"><font><Font size="18" /></font></Label>

    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Username" />
        <TextField fx:id="usernameField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Email" />
        <TextField fx:id="emailField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Phone" />
        <TextField fx:id="phoneField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Name" />
        <TextField fx:id="nameField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Surname" />
        <TextField fx:id="surnameField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Address" />
        <TextField fx:id="addressField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Card No" />
        <TextField fx:id="cardNoField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Bonus Points" />
        <TextField fx:id="bonusPointsField" editable="false" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Balance" />
        <TextField fx:id="balanceField" editable="false" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Date of Birth" />
        <DatePicker fx:id="dateOfBirthPicker" prefHeight="25.0" prefWidth="149.0" />
    </HBox>

    <HBox alignment="TOP_CENTER" spacing="10">
        <Button onAction="#save" text="Save" />
        <Button onAction="#close" text="Close" />
      <Button onAction="#viewUserDetails" text="View User" />
    </HBox>
</VBox>
