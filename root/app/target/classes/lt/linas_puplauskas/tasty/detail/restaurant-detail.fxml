<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefWidth="550.0" spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lt.linas_puplauskas.tasty.fxControllers.detail.RestaurantDetailController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Label text="Restaurant Details"><font><Font size="18" /></font></Label>

    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Username" />
        <TextField fx:id="usernameField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Email" />
        <TextField fx:id="emailField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Phone" />
        <TextField fx:id="phoneField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Address" />
        <TextField fx:id="addressField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Description" />
        <TextArea fx:id="descriptionField" prefHeight="60" prefWidth="149.0" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Cuisine" />
        <ComboBox fx:id="cuisineComboBox" prefHeight="25.0" prefWidth="148.0" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Opening Time" />
        <TextField fx:id="openingTimeField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Closing Time" />
        <TextField fx:id="closingTimeField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Happy Hour Start" />
        <TextField fx:id="happyHourStartField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Happy Hour End" />
        <TextField fx:id="happyHourEndField" />
    </HBox>
    <HBox alignment="CENTER" spacing="10">
        <Label prefWidth="130" text="Rating" />
        <TextField fx:id="ratingField" editable="false" />
    </HBox>

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#save" prefHeight="25.0" prefWidth="48.0" text="Save" />
        <Button onAction="#close" prefHeight="25.0" prefWidth="48.0" text="Close" />
      <Button onAction="#viewUserDetails" prefHeight="25.0" prefWidth="69.0" text="View User" />
    </HBox>
</VBox>
