<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="lt.linas_puplauskas.tasty.fxControllers.LoginInController">

   <VBox alignment="CENTER" spacing="15.0"
         maxWidth="400.0"
         prefWidth="300.0"
         fx:id="rootBox">

      <padding>
         <Insets top="20" right="20" bottom="20" left="20"/>
      </padding>

      <Label text="Welcome to Tasty!">
         <font>
            <Font size="20.0"/>
         </font>
      </Label>

      <TextField fx:id="usernameTextField" promptText="Username"/>
      <PasswordField fx:id="passwordPasswordField" promptText="Password"/>

      <Button text="Login in" onAction="#loginIn"/>

      <HBox alignment="CENTER" spacing="5">
         <Label text="Don't have an Account?"/>
         <Button text="Create" onAction="#routeToRegister"/>
      </HBox>

   </VBox>

</StackPane>